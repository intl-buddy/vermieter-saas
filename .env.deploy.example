# Konfiguration für scripts/migrate.sh (npm run db:migrate).
# Kopiere diese Datei nach .env.deploy (gitignored) und trage die Werte ein.

# SSH-Ziel des Servers (Host-Alias aus ~/.ssh/config oder user@host).
SSH_HOST=deploy@server.example.com

# Namensfilter für den Supabase-DB-Container: docker ps -qf name=<FILTER>
DB_CONTAINER_FILTER=supabase-db

# Passwort des DB-Superusers (PGPASSWORD für psql im Container).
DB_PASSWORD=change-me

# --- Optional (mit Standardwerten) -----------------------------------------
# DB-Benutzer und Datenbank im Container (Default: supabase_admin / postgres).
# DB_USER=supabase_admin
# DB_NAME=postgres

# Basis-URL für die abschließende /api/health-Prüfung (Default unten).
# HEALTH_URL=https://app.tefter.de
