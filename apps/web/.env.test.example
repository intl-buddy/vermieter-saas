# Zugangsdaten für die Playwright-E2E-Tests.
# Kopiere diese Datei nach ".env.test" (ist gitignored) und trage einen
# vorhandenen Test-Nutzer ein.
E2E_EMAIL=test@beispiel.de
E2E_PASSWORD=dein-test-passwort

# Optional: Ziel-Umgebung der Tests. Ohne diese Variable startet Playwright
# selbst einen Dev-Server auf http://localhost:3000. Ist sie gesetzt, wird
# gegen die angegebene, bereits laufende Umgebung getestet.
# E2E_BASE_URL=https://staging.tefter.de
