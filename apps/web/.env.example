# ---------------------------------------------------------------------------
# tefter – Umgebungsvariablen (Vorlage). In Coolify als Build-/Runtime-Vars
# hinterlegen. NEXT_PUBLIC_* werden zur Build-Zeit ins Frontend eingebettet.
# ---------------------------------------------------------------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-Role-Key (nur serverseitig!) – für den Stripe-Webhook, der ohne
# User-Session Nutzerzeilen aktualisiert. NIEMALS ins Frontend geben.
SUPABASE_SERVICE_ROLE_KEY=

# Öffentliche Basis-URL der App (für Stripe success/cancel/return URLs)
NEXT_PUBLIC_SITE_URL=https://app.tefter.de

# Brevo (E-Mail-Versand)
BREVO_API_KEY=

# Secret für den täglichen Lebenszyklus-Lauf (/api/cron/lifecycle).
# Muss als Header `x-cron-secret` mitgeschickt werden.
CRON_SECRET=

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price-IDs je Paket & Abrechnungsintervall (aus dem Stripe-Dashboard).
STRIPE_PRICE_BRONZE_MONTHLY=
STRIPE_PRICE_BRONZE_YEARLY=
STRIPE_PRICE_SILBER_MONTHLY=
STRIPE_PRICE_SILBER_YEARLY=
STRIPE_PRICE_GOLD_MONTHLY=
STRIPE_PRICE_GOLD_YEARLY=
STRIPE_PRICE_PLATIN_MONTHLY=
STRIPE_PRICE_PLATIN_YEARLY=
